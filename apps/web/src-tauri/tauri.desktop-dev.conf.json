{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kompose Dev",
  "identifier": "com.nathancolosimo.kompose.dev",
  "app": {
    "windows": [
      {
        "title": "Kompose Dev",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "titleBarStyle": "Overlay",
        "devtools": true,
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["kompose-dev"]
      }
    }
  }
}
