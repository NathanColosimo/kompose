{
  "name": "kompose",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.4",
  "scripts": {
    "check": "biome check --write .",
    "type-check": "turbo run type-check",
    "dev": "turbo run dev db:studio",
    "build": "turbo run build",
    "build:prod": "turbo run type-check && turbo run build:prod build:prod:desktop --filter=web --filter=native",
    "build:prod:web": "turbo run type-check --filter=web... && turbo run build:prod build:prod:desktop --filter=web",
    "build:prod:native": "turbo run type-check --filter=native... && turbo run build:prod --filter=native",
    "submit:prod": "turbo run submit:prod submit:prod:desktop --filter=web --filter=native",
    "submit:prod:web": "turbo run submit:prod submit:prod:desktop --filter=web",
    "submit:prod:desktop": "turbo run submit:prod:desktop --filter=web",
    "submit:prod:native": "turbo run submit:prod --filter=native",
    "dev:native": "turbo run dev -F native",
    "dev:web": "turbo run dev devtools db:studio -F web -F @kompose/db",
    "portless:proxy": "sudo portless proxy start --https --tld dev",
    "knip": "knip",
    "db:push": "turbo run db:push -F @kompose/db",
    "db:studio": "turbo run db:studio -F @kompose/db",
    "db:generate": "turbo run db:generate -F @kompose/db",
    "db:migrate": "turbo run db:migrate -F @kompose/db",
    "db:start": "turbo run db:start -F @kompose/db",
    "db:watch": "turbo run db:watch -F @kompose/db",
    "db:stop": "turbo run db:stop -F @kompose/db",
    "db:down": "turbo run db:down -F @kompose/db"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@effect/language-service": "^0.82.0",
    "@types/bun": "^1.3.11",
    "knip": "^6.0.4",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "ultracite": "^7.3.2"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@better-auth/expo": "^1.5.6",
      "@ai-sdk/openai": "^3.0.48",
      "@ai-sdk/react": "^3.0.139",
      "@orpc/client": "^1.13.9",
      "@orpc/contract": "^1.13.9",
      "@orpc/ai-sdk": "^1.13.9",
      "@orpc/experimental-ratelimit": "^1.13.9",
      "@orpc/openapi": "^1.13.9",
      "@orpc/server": "^1.13.9",
      "@orpc/zod": "^1.13.9",
      "@t3-oss/env-nextjs": "^0.13.11",
      "@tanstack/react-query": "^5.95.2",
      "@tanstack/react-query-devtools": "^5.95.2",
      "@types/node": "^25.5.0",
      "@types/react": "~19.2.2",
      "@types/react-dom": "~19.2.2",
      "better-auth": "^1.5.6",
      "ai": "^6.0.137",
      "dotenv": "^17.3.1",
      "drizzle-orm": "^0.45.1",
      "effect": "^3.21.0",
      "jotai": "^2.18.1",
      "jotai-family": "^1.0.1",
      "jotai-tanstack-query": "^0.11.0",
      "react-hook-form": "^7.72.0",
      "next": "^16.2.1",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "tailwindcss": "^4.2.2",
      "tailwind-merge": "^3.5.0",
      "temporal-polyfill": "^0.3.2",
      "typescript": "^6.0.2",
      "resumable-stream": "^2.2.12",
      "uuidv7": "^1.2.1",
      "zod": "^4.3.6",
      "@effect/opentelemetry": "^0.63.0",
      "@opentelemetry/api": "^1.9.0",
      "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
      "@opentelemetry/instrumentation": "^0.213.0",
      "@opentelemetry/instrumentation-fetch": "^0.213.0",
      "@opentelemetry/sdk-metrics": "^2.6.0",
      "@opentelemetry/sdk-node": "^0.213.0",
      "@opentelemetry/sdk-trace-base": "^2.6.0",
      "@opentelemetry/sdk-trace-node": "^2.6.0",
      "@opentelemetry/resources": "^2.6.0",
      "@opentelemetry/sdk-trace-web": "^2.6.0",
      "@opentelemetry/semantic-conventions": "^1.40.0",
      "@orpc/otel": "^1.13.9"
    }
  },
  "dependencies": {}
}
